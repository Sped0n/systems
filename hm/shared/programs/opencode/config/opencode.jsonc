{
  "$schema": "https://opencode.ai/config.json",
  // general
  "autoupdate": false,
  "model": "circe-responses/gpt-5.6-sol",
  "small_model": "circe-completions/grok-build-0.1",
  "default_agent": "plan",
  "lsp": false,
  "formatter": false,
  // providers
  "provider": {
    "circe-completions": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Circe",
      "options": {
        "baseURL": "https://circe.sped0n.com/v1",
        "apiKey": "{env:CIRCE_API_KEY}",
        "setCacheKey": true,
        "headerTimeout": 300000,
      },
      "models": {
        "grok-build-0.1": {
          "name": "Grok Build 0.1",
          "cost": {
            "input": 1,
            "output": 2,
            "cache_read": 0.2,
          },
          "limit": {
            "context": 256000,
            "input": 200000,
            "output": 256000,
          },
          "options": {
            "reasoning": {
              "enabled": true,
            },
          },
        },
      },
    },
    "circe-responses": {
      "npm": "@ai-sdk/openai",
      "name": "Circe",
      "options": {
        "baseURL": "https://circe.sped0n.com/v1",
        "apiKey": "{env:CIRCE_API_KEY}",
        "setCacheKey": true,
        "headerTimeout": 300000,
      },
      "models": {
        "gpt-5.6-sol": {
          "name": "GPT-5.6 Sol",
          "cost": {
            "input": 5,
            "cache_write": 6.25,
            "output": 30,
            "cache_read": 0.5,
          },
          "limit": {
            "context": 500000,
            "input": 372000,
            "output": 128000,
          },
          "options": {
            "textVerbosity": "low",
            "reasoningSummary": "concise",
            "service_tier": "default",
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
            },
            "medium": {
              "reasoningEffort": "medium",
            },
            "high": {
              "reasoningEffort": "high",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
            },
          },
        },
        "gpt-5.6-terra": {
          "name": "GPT-5.6 Terra",
          "cost": {
            "input": 2.5,
            "cache_write": 3.125,
            "output": 15,
            "cache_read": 0.25,
          },
          "limit": {
            "context": 500000,
            "input": 372000,
            "output": 128000,
          },
          "options": {
            "textVerbosity": "low",
            "reasoningSummary": "concise",
            "service_tier": "default",
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
            },
            "medium": {
              "reasoningEffort": "medium",
            },
            "high": {
              "reasoningEffort": "high",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
            },
          },
        },
      },
    },
  },
  // global settings
  "permission": {
    "websearch": "deny",
    "webfetch": "deny",
    "external_directory": {
      "/nix/store/**": "allow",
      "~/.cache/checkouts/**": "allow",
      "~/.config/opencode/skills/**": "allow",
    },
    "edit": {
      "/nix/store/**": "deny",
      "~/.cache/checkouts/**": "deny",
      "~/.config/opencode/skills/**": "deny",
    },
  },
  // agents
  "agent": {
    "plan": {
      "model": "circe-responses/gpt-5.6-sol",
      "variant": "medium",
      "temperature": 0.1,
    },
    "build": {
      "model": "circe-responses/gpt-5.6-sol",
      "variant": "medium",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "general": {
      "model": "circe-responses/gpt-5.6-terra",
      "variant": "medium",
      "temperature": 0.25,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "explore": {
      "model": "circe-responses/gpt-5.6-terra",
      "variant": "medium",
      "temperature": 0.0,
      "permission": {
        "skill": {
          "*": "deny",
          "ast-grep": "allow",
          "httpie-cli": "allow",
          "jina-cli": "allow",
        },
      },
    },
    "btw": {
      "description": "Answer one side question without tools or follow-up actions",
      "mode": "subagent",
      "hidden": true,
      "model": "circe-responses/gpt-5.6-sol",
      "variant": "medium",
      "permission": "deny",
    },
    "commit-message-writer": {
      "model": "circe-responses/gpt-5.6-terra",
      "variant": "medium",
    },
    "99": {
      "model": "circe-responses/gpt-5.6-terra",
      "variant": "medium",
    },
  },
}
