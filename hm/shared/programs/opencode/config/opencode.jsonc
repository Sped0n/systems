{
  "$schema": "https://opencode.ai/config.json",
  // general
  "autoupdate": false,
  "model": "newapi-responses/openai/gpt-5.5",
  "small_model": "newapi-completions/minimax/minimax-m2.7",
  "default_agent": "ask",
  "lsp": false,
  "formatter": false,
  // providers
  "provider": {
    "newapi-completions": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "New API",
      "options": {
        "baseURL": "https://newapi.sped0n.com/v1",
        "apiKey": "{env:NEWAPI_API_KEY}",
        "setCacheKey": true,
        "timeout": 150000,
      },
      "models": {
        "minimax/minimax-m2.7": {
          "name": "MiniMax M2.7",
          "cost": {
            "input": 0.3,
            "output": 1.2,
            "cache_read": 0.06,
          },
          "limit": {
            "context": 204800,
            "output": 131072,
          },
          "options": {
            "reasoning": {
              "enabled": true,
            },
            "provider": {
              "sort": "throughput",
              "only": ["fireworks", "minimax"],
            },
          },
        },
      },
    },
    "newapi-responses": {
      "npm": "@ai-sdk/openai",
      "name": "New API",
      "options": {
        "baseURL": "https://newapi.sped0n.com/v1",
        "apiKey": "{env:NEWAPI_API_KEY}",
        "setCacheKey": true,
        "timeout": 150000,
      },
      "models": {
        "openai/gpt-5.5": {
          "name": "GPT-5.5",
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
          },
          "limit": {
            "context": 1050000,
            "input": 272000,
            "output": 128000,
          },
          "options": {
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "include": ["reasoning.encrypted_content"],
            "instructions": "{file:~/.config/opencode/instructions/gpt.txt}",
            "service_tier": "default",
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
            },
            "medium": {
              "reasoningEffort": "medium",
            },
            "high": {
              "reasoningEffort": "high",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
            },
          },
        },
      },
    },
  },
  // global settings
  "permission": {
    "websearch": "deny",
    "webfetch": "deny",
  },
  // agents
  "agent": {
    "plan": {
      "model": "newapi-responses/openai/gpt-5.5",
      "variant": "medium",
      "temperature": 0.1,
      "permission": {
        "skill": {
          "*": "deny",
          "ast-grep": "allow",
          "httpie-cli": "allow",
          "jina-cli": "allow",
        },
      },
    },
    "build": {
      "model": "newapi-responses/openai/gpt-5.5",
      "variant": "medium",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "general": {
      "model": "newapi-responses/openai/gpt-5.5",
      "variant": "low",
      "temperature": 0.25,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "explore": {
      "model": "newapi-completions/minimax/minimax-m2.7",
      "temperature": 0.0,
      "permission": {
        "skill": {
          "*": "deny",
          "ast-grep": "allow",
          "httpie-cli": "allow",
          "jina-cli": "allow",
        },
      },
    },
    "ask": {
      "model": "newapi-responses/openai/gpt-5.5",
      "variant": "medium",
    },
    "commit-message-writer": {
      "model": "newapi-completions/minimax/minimax-m2.7",
    },
    "50": {
      "model": "newapi-completions/minimax/minimax-m2.7",
    },
    "99": {
      "model": "newapi-responses/openai/gpt-5.5",
      "variant": "low",
    },
  },
}
