{
  "$schema": "https://opencode.ai/config.json",
  // general
  "autoupdate": false,
  "model": "newapi-responses/openai/gpt-5.4",
  "small_model": "newapi-completions/moonshotai/kimi-k2.6",
  "default_agent": "ask",
  "lsp": false,
  "formatter": false,
  // providers
  "provider": {
    "newapi-completions": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "New API",
      "options": {
        "baseURL": "https://newapi.sped0n.com/v1",
        "apiKey": "{env:NEWAPI_API_KEY}",
      },
      "models": {
        "moonshotai/kimi-k2.6": {
          "name": "Kimi K2.6",
          "cost": {
            "input": 0.6,
            "output": 3,
            "cache_read": 0.1,
          },
          "limit": {
            "context": 256000,
            "output": 256000,
          },
          "options": {
            "provider": {
              "sort": "throughput",
              "only": ["fireworks", "cloudflare", "moonshotai"],
            },
            "reasoning": {
              "enabled": true,
            },
          },
        },
      },
    },
    "newapi-responses": {
      "npm": "@ai-sdk/openai",
      "name": "New API",
      "options": {
        "baseURL": "https://newapi.sped0n.com/v1",
        "apiKey": "{env:NEWAPI_API_KEY}",
        "setCacheKey": true,
      },
      "models": {
        "openai/gpt-5.4": {
          "name": "GPT-5.4",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
          },
          "limit": {
            "context": 1050000,
            "input": 272000,
            "output": 128000,
          },
          "options": {
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "include": ["reasoning.encrypted_content"],
            "instructions": "{file:~/.config/opencode/instructions/gpt.txt}",
            "service_tier": "default",
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
            },
            "high": {
              "reasoningEffort": "high",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
            },
          },
        },
      },
    },
  },
  // global settings
  "permission": {
    "websearch": "deny",
    "webfetch": "deny",
  },
  // agents
  "agent": {
    "plan": {
      "model": "newapi-responses/openai/gpt-5.4",
      "variant": "high",
      "temperature": 0.1,
      "permission": {
        "skill": {
          "*": "deny",
          "ast-grep": "allow",
          "httpie-cli": "allow",
          "jina-cli": "allow",
        },
      },
    },
    "build": {
      "model": "newapi-responses/openai/gpt-5.4",
      "variant": "high",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "general": {
      "model": "newapi-completions/moonshotai/kimi-k2.6",
      "temperature": 0.25,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "explore": {
      "model": "newapi-completions/moonshotai/kimi-k2.6",
      "temperature": 0.0,
      "permission": {
        "skill": {
          "*": "deny",
          "ast-grep": "allow",
          "httpie-cli": "allow",
          "jina-cli": "allow",
        },
      },
    },
    "ask": {
      "model": "newapi-responses/openai/gpt-5.4",
      "variant": "high",
    },
    "commit-message-writer": {
      "model": "newapi-completions/moonshotai/kimi-k2.6",
    },
    "50": {
      "model": "newapi-completions/moonshotai/kimi-k2.6",
    },
    "99": {
      "model": "newapi-completions/moonshotai/kimi-k2.6",
    },
  },
}
