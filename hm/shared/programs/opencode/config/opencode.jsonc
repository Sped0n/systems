{
  "$schema": "https://opencode.ai/config.json",
  // general
  "autoupdate": false,
  "model": "openrouter/moonshotai/kimi-k2.5",
  "default_agent": "ask",
  "lsp": false,
  // providers
  "provider": {
    "openrouter": {
      "options": {
        "baseURL": "https://aiproxy.sped0n.com/openrouter",
        "setCacheKey": true,
      },
      "models": {
        "moonshotai/kimi-k2.5": {
          "options": {
            "provider": {
              "sort": "throughput",
              "only": ["fireworks", "inceptron", "moonshotai"],
            },
            "reasoning": {
              "enabled": true,
            },
          },
        },
        "x-ai/grok-4.1-fast": {
          "options": {
            "reasoning": {
              "enabled": true,
            },
          },
        },
        "minimax/minimax-m2.7": {
          "options": {
            "provider": {
              "sort": "throughput",
              "only": ["minimax", "novita"],
            },
            "reasoning": {
              "enabled": true,
            },
          },
        },
      },
    },
    "ianepo": {
      "npm": "@ai-sdk/openai",
      "name": "IAnepO",
      "options": {
        "baseURL": "https://aiproxy.sped0n.com/yescode",
        "apiKey": "{env:IANEPO_API_KEY}",
        "setCacheKey": true,
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "cost": {
            "input": 0.5,
            "output": 3,
            "cache_read": 0.05,
          },
          "limit": {
            "context": 1050000,
            "input": 272000,
            "output": 128000,
          },
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "include": ["reasoning.encrypted_content"],
            "instructions": "{file:~/.config/opencode/instructions/gpt.txt}",
            "service_tier": "default",
          },
        },
      },
    },
  },
  // global settings
  "tools": {
    "websearch": false,
    "webfetch": false,
  },
  // agents
  "agent": {
    "plan": {
      "model": "ianepo/gpt-5.4",
      "temperature": 0.1,
      "permission": {
        "skill": {
          "*": "deny",
          "ast-grep": "allow",
        },
      },
    },
    "build": {
      "model": "ianepo/gpt-5.4",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "general": {
      "model": "openrouter/moonshotai/kimi-k2.5",
      "temperature": 0.25,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "explore": {
      "model": "openrouter/x-ai/grok-4.1-fast",
      "temperature": 0.0,
      "permission": {
        "skill": {
          "*": "deny",
          "ast-grep": "allow",
        },
      },
    },
    "ask": {
      "model": "ianepo/gpt-5.4",
    },
    "commit-message-writer": {
      "model": "openrouter/minimax/minimax-m2.7",
    },
    "50": {
      "model": "openrouter/minimax/minimax-m2.7",
    },
    "99": {
      "model": "openrouter/moonshotai/kimi-k2.5",
    },
  },
}
