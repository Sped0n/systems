{
  "$schema": "https://opencode.ai/config.json",
  // general
  "autoupdate": false,
  "model": "circe-responses/gpt-5.5",
  "small_model": "circe-completions/grok-build-0.1",
  "default_agent": "ask",
  "lsp": false,
  "formatter": false,
  // providers
  "provider": {
    "circe-completions": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Circe",
      "options": {
        "baseURL": "https://circe.sped0n.com/v1",
        "apiKey": "{env:CIRCE_API_KEY}",
        "setCacheKey": true,
        "headerTimeout": 300000,
      },
      "models": {
        "grok-build-0.1": {
          "name": "Grok Build 0.1",
          "cost": {
            "input": 1,
            "output": 2,
            "cache_read": 0.2,
          },
          "limit": {
            "context": 256000,
            "input": 200000,
            "output": 256000,
          },
          "options": {
            "reasoning": {
              "enabled": true,
            },
          },
        },
      },
    },
    "circe-responses": {
      "npm": "@ai-sdk/openai",
      "name": "Circe",
      "options": {
        "baseURL": "https://circe.sped0n.com/v1",
        "apiKey": "{env:CIRCE_API_KEY}",
        "setCacheKey": true,
        "headerTimeout": 300000,
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
          },
          "limit": {
            "context": 1050000,
            "input": 272000,
            "output": 128000,
          },
          "options": {
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "include": ["reasoning.encrypted_content"],
            "instructions": "{file:~/.config/opencode/instructions/gpt.txt}",
            "service_tier": "default",
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
            },
            "medium": {
              "reasoningEffort": "medium",
            },
            "high": {
              "reasoningEffort": "high",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
            },
          },
        },
      },
    },
  },
  // global settings
  "permission": {
    "websearch": "deny",
    "webfetch": "deny",
    "external_directory": {
      "/nix/store/**": "allow",
    },
    "edit": {
      "/nix/store/**": "deny",
    },
  },
  // agents
  "agent": {
    "plan": {
      "model": "circe-responses/gpt-5.5",
      "variant": "medium",
      "temperature": 0.1,
      "permission": {
        "skill": {
          "*": "deny",
          "ast-grep": "allow",
          "httpie-cli": "allow",
          "jina-cli": "allow",
        },
      },
    },
    "build": {
      "model": "circe-responses/gpt-5.5",
      "variant": "medium",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "general": {
      "model": "circe-responses/gpt-5.5",
      "variant": "low",
      "temperature": 0.25,
      "permission": {
        "bash": {
          "git *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
        },
      },
    },
    "explore": {
      "model": "circe-completions/grok-build-0.1",
      "temperature": 0.0,
      "permission": {
        "skill": {
          "*": "deny",
          "ast-grep": "allow",
          "httpie-cli": "allow",
          "jina-cli": "allow",
        },
      },
    },
    "ask": {
      "model": "circe-responses/gpt-5.5",
      "variant": "medium",
    },
    "commit-message-writer": {
      "model": "circe-responses/gpt-5.5",
      "variant": "low",
    },
    "50": {
      "model": "circe-completions/grok-build-0.1",
    },
    "99": {
      "model": "circe-responses/gpt-5.5",
      "variant": "low",
    },
  },
}
